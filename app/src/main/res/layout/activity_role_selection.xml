<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

    <!-- App Logo/Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Commicart"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#6200EE"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="32dp"/>

    <!-- Question -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Are you..."
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Role Selection Cards Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="32dp">

    <!-- Artist Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginEnd="8dp"
        app:cardElevation="4dp"
        app:cardCornerRadius="16dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_artists"
        android:tint="#6200EE"/>

    <ImageView
        android:id="@+id/ivArtistCheck"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_check_circle"
        android:visibility="gone"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="An Artist"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvArtistDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\I'd like to sell my works and services online.\"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:lineSpacingExtra="4dp"/>

    </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Customer Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCustomer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        app:cardElevation="4dp"
        app:cardCornerRadius="16dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_customer"
            android:tint="#6200EE"/>

        <ImageView
            android:id="@+id/ivCustomerCheck"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_check_circle"
            android:visibility="gone"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A Customer"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvCustomerDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\I'd like to commission an artist.\"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Create Account Button -->
        <Button
            android:id="@+id/btnCreateAccount"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create an account"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <!-- Login Link -->
        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? Log in"
            android:textSize="14sp"
            android:textColor="#6200EE"
            android:padding="8dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</ScrollView>